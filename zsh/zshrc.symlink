## Oh My ZSH
ZSH=$HOME/.oh-my-zsh
ZSH_THEME="miloshadzic"
source $ZSH/oh-my-zsh.sh
zstyle ':omz:update' mode auto
plugins=() # https://github.com/ohmyzsh/ohmyzsh/wiki/Plugins - Currently not using any so I removed them

autoload bashcompinit

export EDITOR=vim

export PATH="/usr/local/bin:/usr/local/sbin:$PATH:/usr/bin:/bin:/usr/sbin:/sbin"

# NODE
export PATH="./node_modules/.bin:$PATH"

## PYTHON
eval "$(pyenv init --path)"

## RUBY
eval "$(rbenv init -)"
export RUBY_CONFIGURE_OPTS="--with-openssl-dir=$(brew --prefix openssl)"

## Google Clouds SDK
export PATH="/opt/homebrew/share/google-cloud-sdk/bin:$PATH"

# Aliases
alias reload!="source ~/.zshrc"
alias vz="vim ~/.zshrc"
alias a='ls -lrthG'
alias u='cd ..' #up a directory
alias cc='claude --plugin-dir .claude/plugins/brand-image --dangerously-skip-permissions'


[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
export PATH="$HOME/.local/bin:$PATH"
